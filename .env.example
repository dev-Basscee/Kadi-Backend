# Server Configuration
PORT=8080
ENV=development

# Supabase / PostgreSQL Configuration
# MUST use the connection pooler string (Port 6543) for high concurrency
DATABASE_URL=postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis Configuration (Semantic Cache & Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# TxLINE Data Stream (Verifiable Real-time Sports Data)
TXLINE_STREAM_URL=https://api.txline.com/v1/sse/worldcup
TXLINE_API_KEY=your-txline-api-key
