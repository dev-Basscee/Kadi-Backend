# Server Configuration
PORT=8080
ENV=development

# Supabase / PostgreSQL Configuration
# ⚠️  MUST use the Connection Pooler URL — NOT the direct host.
#
# The direct host (db.<ref>.supabase.co) resolves to an IPv6 address.
# Render and many other cloud platforms do NOT support outbound IPv6, causing:
#   dial tcp [...]:6543: connect: network is unreachable
#
# ✅ CORRECT (pooler — IPv4, works on Render):
DATABASE_URL=postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# ❌ WRONG (direct host — IPv6, will fail on Render):
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# To get the correct URL: Supabase Dashboard → Project Settings → Database
# → Connection string → enable "Use connection pooling" → copy the string.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis Configuration (Semantic Cache & Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# TxLINE Data Stream (Verifiable Real-time Sports Data)
TXLINE_STREAM_URL=https://api.txline.com/v1/sse/worldcup
TXLINE_API_KEY=your-txline-api-key
