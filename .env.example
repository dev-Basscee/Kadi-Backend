# Server Configuration
PORT=8080
ENV=development

# Supabase / PostgreSQL Configuration
# MUST use the connection pooler string (Port 6543) for high concurrency
DATABASE_URL=postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis Configuration (Semantic Cache & Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Sports API Configuration
# https://www.api-football.com/ or https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_URL=https://v3.football.api-sports.io

# Worker Settings
LIVE_TICKER_INTERVAL_SEC=12
DAILY_SYNC_INTERVAL_HOURS=24
